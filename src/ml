#!/usr/bin/env python3
"""MindLayer CLI entry point."""

from __future__ import annotations

import argparse
from pathlib import Path
import sys

HERE = Path(__file__).resolve().parent
for candidate in (HERE, HERE.parent / "lib", HERE.parent.parent / "lib"):
    if (candidate / "commands").is_dir():
        sys.path.insert(0, str(candidate))
        break

from commands import archive, boot, diff, load, save, script, session, status
from commands._paths import project_root


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="ml", description="MindLayer command runner")
    subparsers = parser.add_subparsers(dest="command", required=True)

    subparsers.add_parser("boot", help="Print the MindLayer boot receipt")
    subparsers.add_parser("diff", help="Show memory changes since the last session")
    subparsers.add_parser("status", help="Show memory health status")

    load_parser = subparsers.add_parser("load", help="Rank and load memory for a query")
    load_parser.add_argument("query", nargs="+")

    retrieve_parser = subparsers.add_parser("retrieve", help="Alias for load")
    retrieve_parser.add_argument("query", nargs="+")

    session_parser = subparsers.add_parser("session", help="Session context and journal commands")
    session_sub = session_parser.add_subparsers(dest="session_command")
    write_parser = session_sub.add_parser("write", help="Write a dated session journal")
    write_parser.add_argument("--date", default="")
    write_parser.add_argument("--worked-on", dest="worked_on", action="append", default=[])
    write_parser.add_argument("--decisions", dest="decisions", action="append", default=[])
    write_parser.add_argument("--completed", dest="completed", action="append", default=[])
    write_parser.add_argument("--next", dest="next_steps", action="append", default=[])
    write_parser.add_argument("--approval", default="")
    write_parser.add_argument("--approve", action="store_true")
    session_parser.add_argument("--words", type=int, default=0)
    session_parser.add_argument("--context-window", type=int, default=200_000)

    save_parser = subparsers.add_parser("save", help="Write a memory entry to a file")
    save_parser.add_argument("--file", required=True)
    save_parser.add_argument("--section", required=True)
    save_parser.add_argument("--content", required=True)
    save_parser.add_argument("--action", choices=["create", "update"], default="create")
    save_parser.add_argument("--index-entry", dest="index_entry", default="")
    save_parser.add_argument("--scope", choices=["project", "global"], default="project")
    save_parser.add_argument("--approval", default="")
    save_parser.add_argument("--approve", action="store_true")

    clean_parser = subparsers.add_parser("clean", help="Scan memory and propose cleanup actions")
    clean_parser.add_argument("--approve-all", action="store_true")
    clean_parser.add_argument("--scope", choices=["project", "global"], default="project")

    script_parser = subparsers.add_parser("script", help="Run the SCRIPT lifecycle")
    script_sub = script_parser.add_subparsers(dest="script_command", required=True)
    script_sub.add_parser("status", help="Show SCRIPT lifecycle status")

    sig_parser = script_sub.add_parser("signal", help="Record a new signal")
    sig_parser.add_argument("--title", required=True)
    sig_parser.add_argument("--body", required=True)
    sig_parser.add_argument("--tier", choices=["auto", "review"], default="auto")

    cut_parser = script_sub.add_parser("cut", help="Route a signal to backlog or roadmap")
    cut_parser.add_argument("--signal", required=True, dest="sig_id")
    cut_parser.add_argument("--route", choices=["backlog", "roadmap"], required=True)
    cut_parser.add_argument("--reason", default="")
    cut_parser.add_argument("--approve", action="store_true")

    refine_parser = script_sub.add_parser("refine", help="Draft or approve a story")
    refine_parser.add_argument("--backlog-item", dest="backlog_item")
    refine_parser.add_argument("--story-title", dest="story_title")
    refine_parser.add_argument("--approve", action="store_true")
    refine_parser.add_argument("--check", dest="check_path", metavar="FILE")

    story_parser = script_sub.add_parser("story", help="Transition a story status")
    story_ex = story_parser.add_mutually_exclusive_group(required=True)
    story_ex.add_argument("--start", dest="story_id", metavar="ID")
    story_ex.add_argument("--done", dest="story_done_id", metavar="ID")
    story_parser.add_argument("--test-cmd", dest="test_cmd", default="")

    transfer_parser = script_sub.add_parser("transfer", help="Archive done stories and optionally write a learning")
    transfer_parser.add_argument("--backlog-item", required=True, dest="backlog_item")
    transfer_parser.add_argument("--approve", action="store_true")
    transfer_parser.add_argument("--learn", default="")
    transfer_parser.add_argument("--learn-target", choices=["decisions", "project", "risks"], default="decisions", dest="learn_target")
    transfer_parser.add_argument("--approve-learn", action="store_true", dest="approve_learn")

    return parser


def _archive_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="ml archive", description="Internal MindLayer archive/delete command")
    parser.add_argument("--file", required=True)
    parser.add_argument("--section", required=True)
    parser.add_argument("--action", choices=["archive", "delete"], default="archive")
    parser.add_argument("--scope", choices=["project", "global"], default="project")
    parser.add_argument("--approval", default="")
    parser.add_argument("--approve-all", action="store_true")
    return parser


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    root = project_root(Path.cwd())

    if argv and argv[0] == "archive":
        args = _archive_parser().parse_args(argv[1:])
        return archive.run(
            root,
            file=args.file,
            section=args.section,
            action=args.action,
            scope=args.scope,
            approval=args.approval,
            approve_all=args.approve_all,
        )

    args = build_parser().parse_args(argv)

    if args.command == "boot":
        return boot.run(root)
    if args.command == "diff":
        return diff.run(root)
    if args.command in {"load", "retrieve"}:
        return load.run(root, " ".join(args.query))
    if args.command == "status":
        return status.run(root)
    if args.command == "session":
        if getattr(args, "session_command", None) == "write":
            return session.write(
                root,
                session_date=args.date,
                worked_on=args.worked_on or None,
                decisions=args.decisions or None,
                completed=args.completed or None,
                next_steps=args.next_steps or None,
                approval=args.approval,
                approve=args.approve,
            )
        return session.run(root, words=args.words, context_window=args.context_window)
    if args.command == "save":
        return save.run(
            root,
            file=args.file,
            section=args.section,
            content=args.content,
            action=args.action,
            index_entry=args.index_entry,
            scope=args.scope,
            approval=args.approval,
            approve=args.approve,
        )
    if args.command == "clean":
        return archive.clean(root, scope=args.scope, approve_all=args.approve_all)
    if args.command == "script":
        if args.script_command == "status":
            return script.status(root)
        if args.script_command == "signal":
            return script.signal(root, title=args.title, body=args.body, tier=args.tier)
        if args.script_command == "cut":
            return script.cut(root, sig_id=args.sig_id, route=args.route, reason=args.reason, approve=args.approve)
        if args.script_command == "refine":
            check_path = Path(args.check_path) if args.check_path else None
            return script.refine(
                root,
                backlog_item=args.backlog_item or "",
                story_title=args.story_title or "",
                approve=args.approve,
                check_path=check_path,
            )
        if args.script_command == "story":
            story_id = args.story_id or args.story_done_id
            action = "start" if args.story_id else "done"
            return script.story_transition(root, story_id=story_id, action=action, test_cmd=args.test_cmd)
        if args.script_command == "transfer":
            return script.transfer(
                root,
                backlog_item=args.backlog_item,
                approve=args.approve,
                learn=args.learn,
                learn_target=args.learn_target,
                approve_learn=args.approve_learn,
            )
        return 2
    return 2


if __name__ == "__main__":
    sys.exit(main())
